# .env.docker
# Django настройки
SECRET_KEY=django-insecure-docker-key-for-development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# База данных PostgreSQL
DATABASE_NAME=habits_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis (для Celery)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here